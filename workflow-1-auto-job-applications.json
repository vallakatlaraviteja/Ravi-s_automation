      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [900, 600]
    },
    {
      "parameters": {
        "jsCode": "const statusMap = {\n  'under_review': 'Under Review',\n  'interview': 'Interview',\n  'rejected': 'Rejected',\n  'offer': 'Offer',\n  'pending': 'Applied'\n};\n\nconst currentDate = new Date().toISOString().split('T')[0];\nconst apiStatus = items[0].json.status || 'pending';\nconst newStatus = statusMap[apiStatus] || 'Applied';\n\nreturn [\n  {\n    json: {\n      ...items[0].json,\n      'Status': newStatus,\n      'Last Updated': currentDate\n    }\n  }\n];"
      },
      "id": "parse-status",
      "name": "Parse Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 600]
    },
    {
      "parameters": {
        "operation": "update",
        "documentId": {
          "__rl": true,
          "value": "YOUR_SPREADSHEET_ID",
          "mode": "id"
