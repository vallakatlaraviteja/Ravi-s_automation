    {
      "parameters": {
        "jsCode": "// Prepare summary for response\nconst totalJobs = items.length;\nconst jobs = items.map(item => item.json);\n\nconst companies = [...new Set(jobs.map(j => j.company))];\nconst locations = [...new Set(jobs.map(j => j.location))];\n\nreturn [{\n  json: {\n    success: true,\n    totalJobs,\n    searchId: jobs[0]?.searchId || 'unknown',\n    searchQuery: jobs[0]?.searchQuery || '',\n    searchLocation: jobs[0]?.searchLocation || '',\n    uniqueCompanies: companies.length,\n    uniqueLocations: locations.length,\n    message: `Successfully scraped ${totalJobs} jobs from LinkedIn`,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
