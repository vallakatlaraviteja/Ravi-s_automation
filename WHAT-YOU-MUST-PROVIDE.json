{
  "_README": {
    "title": "What YOU Must Provide to Run the MASTER Job Automation Workflow",
    "description": "Complete list of credentials, accounts, IDs, and configuration data needed from your side",
    "instructions": "Follow SETUP-INSTRUCTIONS.md for step-by-step guide on WHERE and HOW to provide each item"
  },

  "SECTION_1_ACCOUNTS_TO_CREATE": {
    "description": "Free accounts you must sign up for (no paid plans required)",
    "accounts": [
      {
        "service": "Groq AI",
        "url": "https://console.groq.com",
        "purpose": "AI-powered job scoring and email generation",
        "free_tier": "14,400 requests/day (30 requests/min)",
        "signup_method": "GitHub or Google sign-in",
        "what_you_get": "API key (starts with 'gsk_')"
      },
      {
        "service": "Google Cloud Console",
        "url": "https://console.cloud.google.com",
        "purpose": "OAuth2 for Google Sheets and Gmail access",
        "free_tier": "Unlimited",
        "signup_method": "Use your existing Google account",
        "what_you_get": "OAuth Client ID and Client Secret"
      },
      {
        "service": "Telegram",
        "url": "https://telegram.org",
        "purpose": "Interactive job assistant bot",
        "free_tier": "Unlimited",
        "signup_method": "Mobile app signup",
        "what_you_get": "Bot token from @BotFather"
      },
      {
        "service": "Adzuna Developer",
        "url": "https://developer.adzuna.com",
        "purpose": "Job search API (one of three job sources)",
        "free_tier": "250 requests/day",
        "signup_method": "Email registration",
        "what_you_get": "Application ID and Application Key"
      }
    ]
  },

  "SECTION_2_CREDENTIALS_TO_PROVIDE": {
    "description": "API keys and tokens you must obtain and add to n8n",
    "credentials": [
      {
        "credential_name": "Groq API",
        "placeholder_in_workflow": "YOUR_GROQ_CREDENTIAL_ID",
        "how_to_get": "Sign up at console.groq.com → API Keys → Create API Key",
        "where_to_add": "n8n → Credentials → Add Credential → Groq API",
        "format": "gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
        "nodes_using_this": [
          "Groq AI: Score Job Match",
          "Groq AI: Generate Personalized Email",
          "Groq Agent (Llama 3.3 70B)"
        ]
      },
      {
        "credential_name": "Google Sheets OAuth2",
        "placeholder_in_workflow": "YOUR_GOOGLE_SHEETS_CREDENTIAL_ID",
        "how_to_get": "Google Cloud Console → APIs & Services → Credentials → Create OAuth Client",
        "where_to_add": "n8n → Credentials → Add Credential → Google Sheets OAuth2 API",
        "format": "OAuth Client ID + Secret",
        "nodes_using_this": [
          "Read Existing Jobs from Sheet",
          "Append to Google Sheets: Jobs Tab",
          "Read Jobs from Sheet for Outreach",
          "Update Sheet: Mark Email Sent",
          "Query Google Sheet for Stats"
        ]
      },
      {
        "credential_name": "Gmail OAuth2",
        "placeholder_in_workflow": "YOUR_GMAIL_CREDENTIAL_ID",
        "how_to_get": "Same OAuth credentials as Google Sheets, enable Gmail API",
        "where_to_add": "n8n → Credentials → Add Credential → Gmail OAuth2 API",
        "format": "OAuth Client ID + Secret (same as Sheets)",
        "nodes_using_this": [
          "Send Gmail: Job Discovery Digest",
          "Send Email via Gmail",
          "Send Gmail: Outreach Digest"
        ]
      },
      {
        "credential_name": "Telegram Bot",
        "placeholder_in_workflow": "YOUR_TELEGRAM_CREDENTIAL_ID",
        "how_to_get": "Telegram → @BotFather → /newbot → follow prompts",
        "where_to_add": "n8n → Credentials → Add Credential → Telegram API",
        "format": "1234567890:ABCdefGHIjklMNOpqrsTUVwxyz",
        "nodes_using_this": [
          "Telegram Trigger: Interactive Assistant",
          "Send Telegram: Job Discovery Digest",
          "Send Quick Reply",
          "Send Telegram Reply (with stats)",
          "Send Telegram Reply (simple)"
        ]
      },
      {
        "credential_name": "Adzuna API",
        "placeholder_in_workflow": "YOUR_ADZUNA_APP_ID and YOUR_ADZUNA_APP_KEY",
        "how_to_get": "developer.adzuna.com → Sign Up → Create Application",
        "where_to_add": "Directly in the 'Fetch Adzuna API' node query parameters (NOT as n8n credential)",
        "format": "app_id: 12345678, app_key: alphanumeric string",
        "nodes_using_this": [
          "Fetch Adzuna API"
        ]
      }
    ]
  },

  "SECTION_3_IDS_TO_OBTAIN": {
    "description": "Specific identifiers you must retrieve and replace in workflow",
    "ids": [
      {
        "id_name": "Google Spreadsheet ID",
        "placeholder_in_workflow": "YOUR_SPREADSHEET_ID",
        "how_to_get": "Create Google Sheet → Open it → Copy ID from URL between /d/ and /edit",
        "example": "1A2B3C4D5E6F7G8H9I0J_K1L2M3N4O5P6Q7R8S9T0",
        "where_to_use": "User Config (Master Profile) node → sheetId field",
        "validation": "36-44 characters, alphanumeric with hyphens and underscores"
      },
      {
        "id_name": "Telegram Chat ID",
        "placeholder_in_workflow": "YOUR_TELEGRAM_CHAT_ID",
        "how_to_get": "Message your bot → Open https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates → Find 'chat':{'id':123456789}",
        "example": "123456789",
        "where_to_use": "Send Telegram: Job Discovery Digest node → chatId parameter",
        "validation": "Numeric, 9-10 digits"
      },
      {
        "id_name": "n8n Credential IDs",
        "placeholder_in_workflow": "Multiple (see SECTION_2 above)",
        "how_to_get": "After adding each credential in n8n → Go to Credentials page → Click credential → Copy ID from URL",
        "example": "groq-api-uuid-abc123",
        "where_to_use": "In each node's credentials section",
        "validation": "UUID or alphanumeric string assigned by n8n"
      }
    ]
  },

  "SECTION_4_PERSONAL_PROFILE_DATA": {
    "description": "Your personal information and job search preferences (use USER-CONFIG-TEMPLATE.json)",
    "config_location": "User Config (Master Profile) node in n8n workflow",
    "required_fields": {
      "personal_info": {
        "name": "Your Full Name",
        "currentRole": "Your Current Job Title",
        "targetRole": "Your Desired Next Role",
        "experience": "X years",
        "location": "City, Country"
      },
      "job_search_criteria": {
        "skills": ["List", "Your", "Top", "5-10", "Skills"],
        "targetRoles": ["Role 1", "Role 2", "Role 3"],
        "keywords": "keyword1 OR keyword2 OR keyword3",
        "workMode": ["remote", "hybrid", "onsite"],
        "minSalary": 80000,
        "country": "Two-letter ISO code (us, gb, in, au, etc.)"
      },
      "urls": {
        "resumeUrl": "https://drive.google.com/file/d/YOUR_RESUME_ID/view",
        "linkedinUrl": "https://linkedin.com/in/yourprofile",
        "githubUrl": "https://github.com/yourusername",
        "portfolioUrl": "https://yourportfolio.com"
      },
      "system_settings": {
        "userEmail": "YOUR_EMAIL@example.com",
        "dailyLimit": 10,
        "scoreThreshold": 30,
        "sheetId": "YOUR_SPREADSHEET_ID (from SECTION_3)"
      }
    }
  },

  "SECTION_5_GOOGLE_SHEET_SETUP": {
    "description": "Google Sheet structure you must create manually",
    "sheet_name": "Jobs",
    "required_columns": [
      "Job ID",
      "Job Title",
      "Company",
      "Location",
      "Work Mode",
      "Salary",
      "Apply URL",
      "Source",
      "Score",
      "Priority",
      "Match Reason",
      "Status",
      "Posted Date",
      "Fetched Date",
      "Recruiter Email",
      "Recruiter Name",
      "Application ID",
      "Email Sent Date",
      "Last Updated"
    ],
    "column_order": "Must be EXACTLY as listed above (A-S, left to right)",
    "row_1": "Column headers (exact names)",
    "row_2_onwards": "Leave empty - workflow populates automatically",
    "access": "Make sure the Google account used for OAuth has edit permissions"
  },

  "SECTION_6_OPTIONAL_CONFIGURATIONS": {
    "description": "Optional settings you can adjust after initial setup",
    "options": [
      {
        "setting": "Schedule Times",
        "default": "8 AM for job discovery, 9 AM for email outreach (UTC timezone)",
        "how_to_change": "Edit cron expressions in Schedule Trigger nodes",
        "example_values": [
          "0 8 * * * (daily 8 AM)",
          "0 9 * * 1-5 (weekdays 9 AM)",
          "0 */6 * * * (every 6 hours)"
        ]
      },
      {
        "setting": "AI Temperature",
        "default": "0.3 for job scoring, 0.7 for email generation",
        "how_to_change": "Edit Groq nodes → options → temperature",
        "example_values": [
          "0.1 (very focused)",
          "0.5 (balanced)",
          "0.9 (very creative)"
        ]
      },
      {
        "setting": "Daily Email Limit",
        "default": "10 emails per day",
        "how_to_change": "User Config node → dailyLimit field",
        "recommendation": "Keep at 10 or lower to avoid spam flags"
      },
      {
        "setting": "Score Threshold",
        "default": "30 (jobs below this are filtered out)",
        "how_to_change": "User Config node → scoreThreshold field",
        "recommendation": "Start at 30, increase if too many irrelevant jobs, decrease if too few"
      }
    ]
  },

