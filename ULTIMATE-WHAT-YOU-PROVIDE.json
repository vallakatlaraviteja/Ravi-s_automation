  "SECTION_4_DATABASE_SETUP": {
    "description": "One-time Supabase database setup",
    "steps": [
      {
        "step": 1,
        "task": "Open Supabase SQL Editor",
        "instructions": [
          "1. Go to your Supabase project dashboard",
          "2. Click 'SQL Editor' on the left sidebar",
          "3. Click 'New query'"
        ]
      },
      {
        "step": 2,
        "task": "Copy the SQL schema",
        "instructions": [
          "1. Open the file: SUPABASE-SCHEMA.sql",
          "2. Select all (Ctrl+A or Cmd+A)",
          "3. Copy (Ctrl+C or Cmd+C)"
        ]
      },
      {
        "step": 3,
        "task": "Paste and run",
        "instructions": [
          "1. Paste into the SQL Editor (Ctrl+V or Cmd+V)",
          "2. Click 'Run' button (or press F5)",
          "3. Wait 5-10 seconds",
          "4. You should see: 'Success. No rows returned'"
        ]
      },
      {
        "step": 4,
        "task": "Verify tables created",
        "instructions": [
          "1. Click 'Table Editor' on the left sidebar",
          "2. You should see 4 tables:",
          "   - jobs",
          "   - email_logs",
          "   - job_stats",
          "   - user_config",
          "3. Click on 'jobs' table - you should see column headers"
        ]
      }
    ],
    "estimated_time": "5 minutes"
  },

