      "id": "webhook-trigger",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [240, 300],
      "webhookId": "linkedin-job-search"
    },
    {
      "parameters": {
        "jsCode": "// Extract and validate form parameters\nconst body = items[0].json.body || {};\n\nconst jobTitle = body.jobTitle || body.job_title || '';\nconst location = body.location || body.city || '';\nconst country = body.country || 'United States';\nconst jobType = body.jobType || body.job_type || 'full-time';\nconst experienceLevel = body.experienceLevel || body.experience_level || '';\nconst remote = body.remote || false;\n\nif (!jobTitle) {\n  throw new Error('Job title is required');\n}\n\nif (!location) {\n  throw new Error('Location is required');\n}\n\nreturn [{\n  json: {\n    jobTitle,\n    location,\n    country,\n    jobType,\n    experienceLevel,\n    remote,\n    searchId: `search-${Date.now()}`,\n    searchDate: new Date().toISOString().split('T')[0]\n  }\n}];"
      },
      "id": "validate-input",
      "name": "Validate Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "url": "https://api.brightdata.com/datasets/v3/trigger",
        "method": "POST",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_BRIGHTDATA_API_KEY"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "dataset_id",
              "value": "gd_l7q7dkf244hwjntr0"
            },
            {
              "name": "endpoint",
              "value": "linkedin_jobs"
            },
            {
              "name": "discover_by",
              "value": "keyword"
            },
