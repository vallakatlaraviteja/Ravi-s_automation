    {
      "parameters": {
        "jsCode": "// Parse and clean LinkedIn job results\nconst results = items[0].json;\nlet jobs = [];\n\nif (Array.isArray(results)) {\n  jobs = results;\n} else if (results.data && Array.isArray(results.data)) {\n  jobs = results.data;\n}\n\n// Clean and format each job\nreturn jobs.map(job => ({\n  json: {\n    jobTitle: job.title || job.job_title || 'Unknown',\n    company: job.company || job.company_name || 'Unknown',\n    location: job.location || 'Not specified',\n    jobType: job.job_type || job.employment_type || 'Full-time',\n    experienceLevel: job.experience_level || job.seniority_level || 'Not specified',\n    salary: job.salary || job.salary_range || 'Not disclosed',\n    applyUrl: job.apply_url || job.job_url || job.url || '',\n    description: (job.description || '').substring(0, 500),\n    postedDate: job.posted_date || job.listed_at || new Date().toISOString().split('T')[0],\n    jobId: job.job_id || job.id || `job-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`,\n    skills: job.skills || [],\n    benefits: job.benefits || [],\n    applicants: job.applicants || job.num_applicants || 'N/A',\n    scrapedDate: new Date().toISOString().split('T')[0],\n    searchId: $('Validate Input').item.json.searchId,\n    searchQuery: $('Validate Input').item.json.jobTitle,\n    searchLocation: $('Validate Input').item.json.location\n  }\n}));"
      },
      "id": "parse-clean-results",
      "name": "Parse & Clean Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2000, 300]
    },
