              "value": "={{ $json.location }}, {{ $json.country }}"
            },
            {
              "name": "job_type",
              "value": "={{ $json.jobType }}"
            },
            {
              "name": "limit",
              "value": "50"
            },
            {
              "name": "include_errors",
              "value": "false"
            },
            {
              "name": "format",
              "value": "json"
            }
          ]
        },
        "options": {}
      },
      "id": "trigger-brightdata-scrape",
      "name": "Trigger Bright Data Scrape",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [680, 300]
    },
    {
      "parameters": {
        "jsCode": "// Extract snapshot_id from Bright Data response\nconst response = items[0].json;\n\nif (!response.snapshot_id) {\n  throw new Error('Failed to trigger Bright Data scrape: no snapshot_id returned');\n}\n\nreturn [{\n  json: {\n    ...items[0].json,\n    snapshotId: response.snapshot_id,\n    status: 'running'\n  }\n}];"
      },
      "id": "extract-snapshot-id",
      "name": "Extract Snapshot ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 300]
