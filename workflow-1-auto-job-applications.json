    {
      "parameters": {
        "sendTo": "YOUR_EMAIL@example.com",
        "subject": "🔔 Application Status Update: {{ $json['Job Title'] }} - {{ $json.Status }}",
        "message": "=Hello,\n\nYour application status has been updated:\n\n**Job Title:** {{ $json['Job Title'] }}\n**Company:** {{ $json.Company }}\n**New Status:** {{ $json.Status }}\n**Application ID:** {{ $json['Application ID'] }}\n**Last Updated:** {{ $json['Last Updated'] }}\n**Job URL:** {{ $json['Job URL'] }}\n\n{% if $json.Status === 'Interview' %}\n🎉 Congratulations! You've been invited for an interview.\n{% elif $json.Status === 'Offer' %}\n🎊 Amazing! You've received a job offer!\n{% elif $json.Status === 'Rejected' %}\nDon't give up! Keep applying to more opportunities.\n{% endif %}\n\nBest regards,\nYour Job Automation System",
        "options": {}
      },
      "id": "send-status-email",
      "name": "Send Status Email",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [1780, 600],
      "credentials": {
